# Machine-local monitor profiles — copy scripts/monitor-profiles.example.sh
# to this path and edit for your hardware.
scripts/monitor-profiles.local.sh

# Machine-local compose key — copy compose_key.local.example to this path.
# The compose key differs per device; the active value is not committed.
compose_key.local
.theme_state
 
# Wallpaper rotation: track the folder (via .gitkeep) but not its contents,
# and never commit the active wp.png symlink — rotate-wallpaper.sh manages it.
# wallpaper_dir.local optionally points rotation at an external folder — copy
# wallpaper_dir.local.example; the path is machine-specific, so not committed.
images/wallpapers/*
!images/wallpapers/.gitkeep
images/wp.png
wallpaper_dir.local

# Waybar active palette symlink — managed by toggle_theme.sh, points at
# waybar/colors-{dark,light}.css depending on current theme state.
waybar/colors.css
