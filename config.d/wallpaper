# Bootstrap the desktop wallpaper on sway start/reload — but only when one is
# not already set. --if-unset makes rotate-wallpaper.sh a no-op whenever
# images/wp.png already points at an existing file, so your chosen wallpaper
# persists across logins and reloads. Rotate on demand with $mod+Shift+w.
# Picks a random .png/.jpg/.jpeg from the pool (images/wallpapers/, or the
# folder named in wallpaper_dir.local if present) and repoints images/wp.png.
exec_always ~/.config/sway/scripts/rotate-wallpaper.sh --if-unset
